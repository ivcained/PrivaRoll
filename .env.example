# ═══════════════════════════════════════════════════
# PrivaRoll Environment Configuration
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ──────────────────────────────────────────────
# Network Configuration (Base Sepolia Testnet)
# ──────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_BASE_MAINNET_RPC_URL=https://mainnet.base.org

# ──────────────────────────────────────────────
# Smart Contract Addresses
# ──────────────────────────────────────────────
# After deploying StealthKeyRegistry, set this:
STEALTH_REGISTRY_ADDRESS=
NEXT_PUBLIC_STEALTH_REGISTRY_ADDRESS=

# ──────────────────────────────────────────────
# Deployer Wallet (for contract deployment)
# ──────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=

# ──────────────────────────────────────────────
# BitGo Enterprise Configuration (PREFERRED)
# ──────────────────────────────────────────────
# Get your access token from https://app.bitgo-test.com (testnet)
# or https://app.bitgo.com (mainnet)
BITGO_ACCESS_TOKEN=
BITGO_WALLET_ID=
BITGO_ENV=test
# Coin identifier: tbaseeth (Base Sepolia testnet) or baseeth (Base mainnet)
BITGO_COIN=tbaseeth

# ──────────────────────────────────────────────
# Direct Signing Fallback (if BitGo is not configured)
# ──────────────────────────────────────────────
# Private key for the HR payroll wallet (used for direct ethers.js signing)
# Only used when BITGO_ACCESS_TOKEN is not set
PAYROLL_PRIVATE_KEY=

# ──────────────────────────────────────────────
# Server Configuration
# ──────────────────────────────────────────────
BACKEND_PORT=4000
BACKEND_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=
NODE_ENV=development
