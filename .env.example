# ═══════════════════════════════════════════════════
#  🛡️  PrivaRoll — Environment Configuration
# ═══════════════════════════════════════════════════
#  Copy this file to .env and fill in your values.
#  DO NOT commit the .env file to version control.
# ═══════════════════════════════════════════════════

# ──────────────────────────────────────────────
# 1. BitGo Configuration
#    Docs: https://developers.bitgo.com/docs/get-started-quick-start
# ──────────────────────────────────────────────

# Your BitGo access token (created at https://app.bitgo-test.com for testnet)
BITGO_ACCESS_TOKEN=your_bitgo_access_token_here

# The BitGo environment: 'test' for testnet, 'prod' for mainnet
BITGO_ENV=test

# The BitGo wallet ID for the HR IssuerMultisig (USDC on Base)
BITGO_HR_WALLET_ID=your_hr_wallet_id_here

# The BitGo wallet passphrase (used to sign transactions)
BITGO_WALLET_PASSPHRASE=your_wallet_passphrase_here

# (Optional) BitGo wallet ID for the GovMultisig (compliance/audit)
BITGO_GOV_WALLET_ID=

# ──────────────────────────────────────────────
# 2. Base Network (L2) Configuration
#    Docs: https://docs.base.org/get-started/base
# ──────────────────────────────────────────────

# Base Sepolia Testnet RPC URL
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Base Mainnet RPC URL (for production)
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Base Sepolia Chain ID: 84532
# Base Mainnet Chain ID: 8453

# ──────────────────────────────────────────────
# 3. Smart Contract Addresses
#    (Filled after running: npx hardhat run scripts/deploy.ts --network base_sepolia)
# ──────────────────────────────────────────────

# StealthKeyRegistry contract address on Base Sepolia
STEALTH_REGISTRY_ADDRESS=

# USDC contract address on Base Sepolia
# Official Base Sepolia USDC: Check https://docs.base.org for latest address
USDC_CONTRACT_ADDRESS=

# ──────────────────────────────────────────────
# 4. Deployer / Signer Configuration
# ──────────────────────────────────────────────

# Private key of the deployer account (for Hardhat deployments)
# WARNING: Never commit real private keys! Use a dedicated testnet account.
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here

# ──────────────────────────────────────────────
# 5. Backend Server Configuration
# ──────────────────────────────────────────────

# Port for the Express backend server
BACKEND_PORT=4000

# Node environment
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ──────────────────────────────────────────────
# 6. Frontend (Next.js) Public Variables
#    Prefix with NEXT_PUBLIC_ to expose to the browser
# ──────────────────────────────────────────────

# Base Sepolia RPC URL (public, for wagmi/viem in-browser)
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Base Mainnet RPC URL (public)
NEXT_PUBLIC_BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# StealthKeyRegistry contract address (public)
NEXT_PUBLIC_STEALTH_REGISTRY_ADDRESS=

# USDC contract address (public)
NEXT_PUBLIC_USDC_CONTRACT_ADDRESS=

# ──────────────────────────────────────────────
# 7. Block Explorer / Verification
# ──────────────────────────────────────────────

# BaseScan API key (for contract verification)
BASESCAN_API_KEY=

# Enable gas reporting in tests
REPORT_GAS=false